<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Игра Слова на букву</title>
    
    <!-- Подключаем Tailwind CSS для стилей -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Настройка Import Map для React и иконок -->
    <script type="importmap">
    {
        "imports": {
            "react": "https://esm.sh/react@18.2.0",
            "react-dom/client": "https://esm.sh/react-dom@18.2.0/client",
            "lucide-react": "https://esm.sh/lucide-react@0.263.1"
        }
    }
    </script>
    
    <!-- Подключаем Babel для обработки JSX в браузере -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
        /* Скрываем скроллбары для чистоты интерфейса */
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        
        @keyframes fadeIn {
          from { opacity: 0; transform: translateY(10px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes scaleIn {
          from { opacity: 0; transform: scale(0.95); }
          to { opacity: 1; transform: scale(1); }
        }
        .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }
        .animate-scale-in { animation: scaleIn 0.3s ease-out forwards; }
    </style>
</head>
<body class="bg-gray-100 text-gray-900 h-screen w-full overflow-hidden selection:bg-indigo-100">
    <div id="root" class="h-full w-full"></div>

    <script type="text/babel" data-type="module">
        import React, { useState, useEffect, useRef } from 'react';
        import { createRoot } from 'react-dom/client';
        import { 
            Play, Pause, SkipForward, Square, Clock, Settings, RotateCcw, 
            Info, Zap, Sparkles, ChevronLeft, Sliders, Type, Hash, BookOpen, Volume2, VolumeX
        } from 'lucide-react';

        // --- ДАННЫЕ ДЛЯ ИГРЫ ---
        
        // Буквы русского алфавита (без сложных Ъ, Ь, Ы, Й)
        const LETTERS = [
            'А', 'Б', 'В', 'Г', 'Д', 'Е', 'Ж', 'З', 'И', 'К', 
            'Л', 'М', 'Н', 'О', 'П', 'Р', 'С', 'Т', 'У', 'Ф', 
            'Х', 'Ц', 'Ч', 'Ш', 'Щ', 'Э', 'Ю', 'Я'
        ];

        // Темы для генерации
        const TOPICS = [
            'Еда и напитки', 'Путешествия и страны', 'Профессии', 'Животные и птицы', 
            'Города', 'Спорт и инвентарь', 'Одежда и обувь', 'Технологии и гаджеты', 
            'Кино и искусство', 'Природа и растения', 'Чувства и эмоции', 'Дом и мебель', 
            'Школа и учеба', 'Хобби и развлечения', 'Транспорт', 'Космос', 
            'Музыка и инструменты', 'Наука', 'Медицина и здоровье', 'Бизнес и деньги'
        ];

        const DURATION_PRESETS = [60, 180, 300, 600, 900];
        const INTERVAL_PRESETS = [15, 30, 45, 60, 90];

        // --- УТИЛИТЫ ---

        const formatTime = (seconds) => {
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return `${m}:${s < 10 ? '0' : ''}${s}`;
        };

        const getRandomItem = (array, history = []) => {
            const available = array.filter(item => !history.includes(item));
            if (available.length === 0) {
                // Если всё использовали, берем просто случайное из всего массива
                return array[Math.floor(Math.random() * array.length)];
            }
            return available[Math.floor(Math.random() * available.length)];
        };

        // --- ПРИЛОЖЕНИЕ ---

        function App() {
            const [screen, setScreen] = useState('SETTINGS'); 
            const [showSettings, setShowSettings] = useState(false);

            // Настройки
            const [totalDuration, setTotalDuration] = useState(180);
            const [pairInterval, setPairInterval] = useState(30);
            const [useTopic, setUseTopic] = useState(true);
            const [soundEnabled, setSoundEnabled] = useState(true);
            
            // Состояние игры
            const [isPlaying, setIsPlaying] = useState(false);
            const [roundTimeLeft, setRoundTimeLeft] = useState(0);
            const [pairTimeLeft, setPairTimeLeft] = useState(0);
            
            const [currentLetter, setCurrentLetter] = useState('');
            const [currentTopic, setCurrentTopic] = useState('');
            
            const [lettersHistory, setLettersHistory] = useState([]);
            const [topicsHistory, setTopicsHistory] = useState([]);
            const [pairsCount, setPairsCount] = useState(0);

            const tickRate = 100;
            const timerRef = useRef(null);
            
            // Звук (Web Audio API)
            const audioCtxRef = useRef(null);

            const initAudio = () => {
                if (!audioCtxRef.current) {
                    const AudioContext = window.AudioContext || window.webkitAudioContext;
                    if (AudioContext) audioCtxRef.current = new AudioContext();
                }
                if (audioCtxRef.current && audioCtxRef.current.state === 'suspended') {
                    audioCtxRef.current.resume();
                }
            };

            const playTick = () => {
                if (!soundEnabled || !audioCtxRef.current) return;
                try {
                    const ctx = audioCtxRef.current;
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(1000, ctx.currentTime);
                    gain.gain.setValueAtTime(0.05, ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.05);
                    osc.start();
                    osc.stop(ctx.currentTime + 0.05);
                } catch(e) {}
            };

            const playBeep = () => {
                if (!soundEnabled || !audioCtxRef.current) return;
                try {
                    const ctx = audioCtxRef.current;
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(600, ctx.currentTime);
                    gain.gain.setValueAtTime(0.1, ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.15);
                    osc.start();
                    osc.stop(ctx.currentTime + 0.15);
                } catch(e) {}
            };

            const playEndSound = () => {
                if (!soundEnabled || !audioCtxRef.current) return;
                try {
                    const ctx = audioCtxRef.current;
                    const osc = ctx.createOscillator();
                    const gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(400, ctx.currentTime);
                    osc.frequency.setValueAtTime(600, ctx.currentTime + 0.2);
                    gain.gain.setValueAtTime(0.1, ctx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.00001, ctx.currentTime + 0.5);
                    osc.start();
                    osc.stop(ctx.currentTime + 0.5);
                } catch(e) {}
            };

            // --- ЛОГИКА ---

            const startGame = (overrides = {}) => {
                initAudio(); // Инициализация аудиоконтекста после клика
                const configDuration = overrides.duration || totalDuration;
                const configInterval = overrides.interval || pairInterval;
                const configUseTopic = overrides.useTopic !== undefined ? overrides.useTopic : useTopic;

                if (overrides.duration) setTotalDuration(overrides.duration);
                if (overrides.interval) setPairInterval(overrides.interval);
                if (overrides.useTopic !== undefined) setUseTopic(overrides.useTopic);

                setRoundTimeLeft(configDuration);
                setPairTimeLeft(configInterval);
                setLettersHistory([]);
                setTopicsHistory([]);
                setPairsCount(0);
                
                const firstLetter = getRandomItem(LETTERS, []);
                const firstTopic = configUseTopic ? getRandomItem(TOPICS, []) : '';
                
                setCurrentLetter(firstLetter);
                setCurrentTopic(firstTopic);
                setLettersHistory([firstLetter]);
                if (firstTopic) setTopicsHistory([firstTopic]);
                
                setIsPlaying(true);
                setScreen('GAME');
            };

            const handleQuickStart = () => {
                startGame({
                    duration: 180, // 3 минуты всего
                    interval: 30,   // 30 секунд на букву
                    useTopic: true
                });
            };

            const nextPair = () => {
                const newLetter = getRandomItem(LETTERS, lettersHistory);
                const newTopic = useTopic ? getRandomItem(TOPICS, topicsHistory) : '';
                
                setCurrentLetter(newLetter);
                setCurrentTopic(newTopic);
                
                setLettersHistory(prev => [...prev, newLetter]);
                if (newTopic) setTopicsHistory(prev => [...prev, newTopic]);
                
                setPairsCount(prev => prev + 1);
                setPairTimeLeft(pairInterval);
            };

            const stopGame = () => {
                setIsPlaying(false);
                if (timerRef.current) clearInterval(timerRef.current);
                setScreen('RESULTS');
            };

            useEffect(() => {
                if (screen === 'GAME' && isPlaying) {
                    timerRef.current = setInterval(() => {
                        
                        setRoundTimeLeft(prev => {
                            const next = prev - (tickRate / 1000);
                            if (next <= 0) {
                                playEndSound();
                                stopGame();
                                return 0;
                            }
                            return next;
                        });

                        setPairTimeLeft(prev => {
                            const next = prev - (tickRate / 1000);
                            
                            // Звук тиканья на последних 3 секундах
                            if (Math.floor(prev) > Math.floor(next) && Math.floor(next) > 0 && Math.floor(next) <= 3) {
                                playTick();
                            }
                            
                            if (next <= 0) {
                                playBeep();
                                nextPair();
                                return pairInterval;
                            }
                            return next;
                        });

                    }, tickRate);
                } else {
                    clearInterval(timerRef.current);
                }
                return () => clearInterval(timerRef.current);
            }, [screen, isPlaying, pairInterval, lettersHistory, topicsHistory, soundEnabled]);

            // --- ЭКРАНЫ ---

            const renderStartScreen = () => {
                if (showSettings) return renderSettings();
                
                return (
                    <div className="flex flex-col h-full max-w-md mx-auto p-6 animate-fade-in bg-white justify-center">
                        <div className="text-center mb-8">
                            <div className="inline-flex items-center justify-center p-4 bg-indigo-50 rounded-2xl mb-4">
                                <Type className="w-10 h-10 text-indigo-600" />
                            </div>
                            <h1 className="text-4xl font-black text-gray-900 mb-2">Слова на букву</h1>
                            
                            <div className="bg-indigo-50/50 rounded-xl p-3 max-w-xs mx-auto border border-indigo-100">
                                <p className="text-indigo-900 text-sm font-medium leading-snug">
                                   ⚡️ Бот дает <b>Букву</b> и (если включено) <b>Тему</b>.<br/> 
                                   Называй <b>существительные</b> вслух, стараясь <span className="text-indigo-600 font-bold">избегать пауз "эээ"</span>.
                                </p>
                            </div>
                        </div>

                        <div className="space-y-4 w-full">
                            <button
                                onClick={handleQuickStart}
                                className="w-full group relative bg-indigo-600 hover:bg-indigo-700 text-white p-5 rounded-2xl shadow-xl transition-all active:scale-95 flex items-center justify-between overflow-hidden"
                            >
                                <div className="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform"></div>
                                <div className="flex items-center gap-4">
                                    <div className="bg-white/20 p-2 rounded-xl">
                                        <Zap className="w-6 h-6 text-white" />
                                    </div>
                                    <div className="text-left">
                                        <div className="font-bold text-xl leading-none mb-1">Быстрый старт</div>
                                        <div className="text-indigo-100 text-xs font-medium">Смена каждые 30 сек</div>
                                    </div>
                                </div>
                                <div className="bg-white/20 p-2 rounded-full">
                                    <Play className="w-5 h-5 fill-current" />
                                </div>
                            </button>

                            <button
                                onClick={() => setShowSettings(true)}
                                className="w-full bg-white border-2 border-gray-100 hover:border-gray-300 text-gray-700 p-5 rounded-2xl transition-all active:bg-gray-50 flex items-center justify-between"
                            >
                                <div className="flex items-center gap-4">
                                    <div className="bg-gray-100 p-2 rounded-xl">
                                        <Sliders className="w-6 h-6 text-gray-500" />
                                    </div>
                                    <div className="text-left">
                                        <div className="font-bold text-lg leading-none mb-1">Своя игра</div>
                                        <div className="text-gray-400 text-xs font-medium">Настройки времени и звука</div>
                                    </div>
                                </div>
                                <div className="text-gray-300">
                                    <ChevronLeft className="w-5 h-5 rotate-180" />
                                </div>
                            </button>
                        </div>

                        <div className="mt-8 flex justify-center">
                            <button onClick={() => setScreen('RULES')} className="text-gray-400 font-medium text-sm flex items-center gap-2 hover:text-gray-600 transition-colors">
                                <Info className="w-4 h-4" /> Как играть?
                            </button>
                        </div>
                    </div>
                );
            };

            const renderSettings = () => (
                <div className="flex flex-col h-full max-w-md mx-auto p-4 animate-fade-in bg-gray-50">
                    <div className="flex items-center justify-between mb-6 mt-2">
                        <button 
                            onClick={() => setShowSettings(false)}
                            className="p-2 -ml-2 text-gray-400 hover:text-gray-700 rounded-full hover:bg-gray-100 transition-colors"
                        >
                            <ChevronLeft size={24} />
                        </button>
                        <h2 className="text-xl font-bold text-gray-800">Настройки</h2>
                        <div className="w-10"></div> {/* Spacer for center alignment */}
                    </div>

                    <div className="flex-1 space-y-4">
                        {/* Звук */}
                        <div className="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 flex justify-between items-center">
                            <label className="text-sm font-bold text-gray-700 flex items-center gap-2">
                                {soundEnabled ? <Volume2 className="w-5 h-5 text-indigo-500" /> : <VolumeX className="w-5 h-5 text-gray-400" />}
                                Звуковые сигналы таймера
                            </label>
                            <button
                                onClick={() => setSoundEnabled(!soundEnabled)}
                                className={`w-14 h-8 rounded-full relative transition-colors ${soundEnabled ? 'bg-indigo-600' : 'bg-gray-300'}`}
                            >
                                <div className={`absolute top-1 w-6 h-6 rounded-full bg-white transition-transform ${soundEnabled ? 'left-7' : 'left-1'}`} />
                            </button>
                        </div>

                        <div className="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                            <label className="block text-sm font-bold text-gray-700 mb-4 flex items-center gap-2">
                                <Clock className="w-5 h-5 text-indigo-500" /> Общее время игры
                            </label>
                            <div className="grid grid-cols-3 gap-2">
                                {DURATION_PRESETS.map(t => (
                                    <button
                                        key={t}
                                        onClick={() => setTotalDuration(t)}
                                        className={`py-3 px-2 rounded-xl text-sm font-bold transition-all ${
                                            totalDuration === t 
                                            ? 'bg-indigo-600 text-white shadow-md' 
                                            : 'bg-gray-50 border border-gray-200 text-gray-600 hover:bg-gray-100'
                                        }`}
                                    >
                                        {t >= 60 ? `${t/60} мин` : `${t} с`}
                                    </button>
                                ))}
                            </div>
                        </div>

                        <div className="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                            <label className="block text-sm font-bold text-gray-700 mb-4 flex items-center gap-2">
                                <Hash className="w-5 h-5 text-indigo-500" /> Смена буквы каждые
                            </label>
                            <div className="grid grid-cols-3 gap-2">
                                {INTERVAL_PRESETS.map(t => (
                                    <button
                                        key={t}
                                        onClick={() => setPairInterval(t)}
                                        className={`py-3 px-2 rounded-xl text-sm font-bold transition-all ${
                                            pairInterval === t 
                                            ? 'bg-indigo-600 text-white shadow-md' 
                                            : 'bg-gray-50 border border-gray-200 text-gray-600 hover:bg-gray-100'
                                        }`}
                                    >
                                        {t} сек
                                    </button>
                                ))}
                            </div>
                        </div>

                        <div className="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                            <label className="block text-sm font-bold text-gray-700 mb-4 flex items-center gap-2">
                                <BookOpen className="w-5 h-5 text-indigo-500" /> Режим игры
                            </label>
                            <div className="grid grid-cols-2 gap-2">
                                <button
                                    onClick={() => setUseTopic(true)}
                                    className={`py-3 px-2 rounded-xl text-sm font-bold transition-all ${
                                        useTopic 
                                        ? 'bg-indigo-600 text-white shadow-md' 
                                        : 'bg-gray-50 border border-gray-200 text-gray-600 hover:bg-gray-100'
                                    }`}
                                >
                                    Случайная тема
                                </button>
                                <button
                                    onClick={() => setUseTopic(false)}
                                    className={`py-3 px-2 rounded-xl text-sm font-bold transition-all ${
                                        !useTopic 
                                        ? 'bg-indigo-600 text-white shadow-md' 
                                        : 'bg-gray-50 border border-gray-200 text-gray-600 hover:bg-gray-100'
                                    }`}
                                >
                                    Без темы
                                </button>
                            </div>
                        </div>
                    </div>

                    <button
                        onClick={() => startGame()}
                        className="w-full bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white font-bold py-4 rounded-xl shadow-lg transition-colors text-lg mt-4 flex items-center justify-center gap-2 shrink-0"
                    >
                        Начать игру
                    </button>
                </div>
            );

            const renderRules = () => (
                <div className="flex flex-col h-full max-w-md mx-auto p-4 animate-fade-in bg-white">
                    <div className="text-center mb-6 mt-2">
                        <h2 className="text-2xl font-bold text-gray-800">Как это работает?</h2>
                    </div>
                    
                    <div className="flex-1 overflow-y-auto space-y-4 pb-4 text-gray-700">
                        <div className="bg-indigo-50 p-5 rounded-2xl border border-indigo-100">
                            <h3 className="font-bold text-indigo-900 mb-2 flex items-center gap-2">
                                <Sparkles className="w-5 h-5 text-indigo-600" /> Суть тренажера
                            </h3>
                            <p className="text-sm font-medium leading-relaxed text-indigo-800">
                                Это жесткий и эффективный тренажер для активного словарного запаса. Он учит быстро доставать нужные слова из памяти и строить плотную речь.
                            </p>
                        </div>

                        <div className="bg-gray-50 p-5 rounded-2xl border border-gray-100">
                            <h3 className="font-bold text-gray-800 mb-3">Правила:</h3>
                            <ul className="space-y-3 text-sm">
                                <li className="flex gap-2">
                                    <span className="font-bold text-indigo-600">1.</span> 
                                    <span>Бот выдает <b>Случайную Букву</b> и, если включено, <b>Тему</b> (например, Буква "К", Тема "Еда").</span>
                                </li>
                                <li className="flex gap-2">
                                    <span className="font-bold text-indigo-600">2.</span> 
                                    <span>До конца таймера называй вслух слова на эту букву. <b>Старайся называть только имена существительные</b> (например: Картошка, Капуста, Кефир).</span>
                                </li>
                                <li className="flex gap-2">
                                    <span className="font-bold text-indigo-600">3.</span> 
                                    <span>Главное правило: <b>старайся не замолкать</b> и убрать звуки-паразиты "эээ", "ммм".</span>
                                </li>
                                <li className="flex gap-2">
                                    <span className="font-bold text-indigo-600">4.</span> 
                                    <span><b>Игра с друзьями:</b> передавайте телефон по кругу или играйте вместе. Соревнуйтесь, кто назовет больше слов за отведенное время!</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                    
                    <button onClick={() => setScreen('SETTINGS')} className="bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-4 rounded-xl w-full transition-colors">
                        Понятно, назад
                    </button>
                </div>
            );

            const renderGame = () => {
                const progress = (pairTimeLeft / pairInterval) * 100;
                const isUrgent = pairTimeLeft < 4; 

                return (
                    <div className="flex flex-col h-full max-w-md mx-auto bg-gray-50">
                        <div className="flex justify-between items-center p-4">
                            <div className="flex items-center gap-2 bg-white px-3 py-1.5 rounded-full shadow-sm border border-gray-200">
                                <Clock className="w-4 h-4 text-gray-400" />
                                <span className="font-mono font-bold text-gray-700 text-lg">{formatTime(Math.ceil(roundTimeLeft))}</span>
                            </div>
                            <button onClick={stopGame} className="p-2 text-red-400 hover:bg-red-50 hover:text-red-600 rounded-full transition-colors">
                                <Square className="w-5 h-5 fill-current" />
                            </button>
                        </div>

                        <div className="flex-1 flex flex-col items-center justify-center p-6 relative">
                            {/* Topic Badge */}
                            {currentTopic && (
                                <div key={currentTopic} className="mb-4 animate-fade-in bg-indigo-600 text-white px-6 py-2 rounded-full shadow-md flex items-center gap-2 z-10">
                                    <span className="text-xs uppercase tracking-wider opacity-80">Тема:</span>
                                    <span className="text-sm font-bold uppercase tracking-wide">{currentTopic}</span>
                                </div>
                            )}
                            
                            {/* Giant Letter */}
                            <div key={currentLetter} className="animate-scale-in flex items-center justify-center w-full z-10">
                                <h1 className="text-[140px] leading-none font-black text-gray-900 drop-shadow-sm">
                                    {currentLetter}
                                </h1>
                            </div>

                            {/* Timer */}
                            <div className="relative w-32 h-32 flex items-center justify-center mt-6 z-10">
                                <svg className="w-full h-full transform -rotate-90">
                                    <circle cx="64" cy="64" r="56" className="stroke-gray-200" strokeWidth="8" fill="transparent" />
                                    <circle 
                                        cx="64" cy="64" r="56" 
                                        className={`transition-all duration-100 ease-linear ${isUrgent ? 'stroke-red-500' : 'stroke-indigo-500'}`} 
                                        strokeWidth="8" fill="transparent" 
                                        strokeDasharray={351.8} 
                                        strokeDashoffset={351.8 - (351.8 * progress) / 100} 
                                        strokeLinecap="round" 
                                    />
                                </svg>
                                <span className={`absolute text-4xl font-black font-mono ${isUrgent ? 'text-red-600' : 'text-indigo-600'}`}>
                                    {Math.ceil(pairTimeLeft)}
                                </span>
                            </div>
                            
                            <p className="text-xs text-gray-400 mt-3 uppercase tracking-widest font-bold">смена буквы</p>
                        </div>

                        <div className="bg-white p-4 border-t border-gray-200 shadow-[0_-10px_30px_rgba(0,0,0,0.05)] relative z-20">
                            <div className="max-w-sm mx-auto flex items-center gap-4">
                                <button onClick={() => {
                                    initAudio(); // Подстраховка для снятия блокировки звука
                                    setIsPlaying(!isPlaying);
                                }} className="p-4 rounded-2xl bg-gray-100 text-gray-700 font-bold hover:bg-gray-200 shrink-0 transition-colors">
                                    {isPlaying ? <Pause className="w-6 h-6" /> : <Play className="w-6 h-6" />}
                                </button>
                                <button onClick={() => {
                                    if(soundEnabled) playBeep();
                                    nextPair();
                                }} disabled={!isPlaying} className="flex-1 flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50 text-white py-4 rounded-2xl font-bold text-xl shadow-md active:scale-95 transition-all">
                                    Дальше <SkipForward className="w-6 h-6" />
                                </button>
                            </div>
                        </div>

                        {!isPlaying && (
                            <div className="absolute inset-0 bg-white/90 backdrop-blur-sm z-50 flex items-center justify-center">
                                <div className="text-center p-8 bg-white shadow-2xl rounded-3xl border border-gray-100 max-w-xs mx-4">
                                    <h2 className="text-2xl font-bold text-gray-800 mb-2">Пауза</h2>
                                    <button onClick={() => {
                                        initAudio();
                                        setIsPlaying(true);
                                    }} className="w-full bg-indigo-600 text-white font-bold py-3.5 rounded-xl shadow-lg mt-4 transition-transform active:scale-95">
                                        Продолжить
                                    </button>
                                </div>
                            </div>
                        )}
                    </div>
                );
            };

            const renderResults = () => {
                const timeSpent = totalDuration - Math.max(0, roundTimeLeft);
                return (
                    <div className="flex flex-col h-full max-w-md mx-auto p-4 animate-fade-in justify-center bg-gray-50">
                        <div className="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
                            <div className="bg-indigo-600 p-8 text-center text-white">
                                <h1 className="text-3xl font-bold mb-2">Тренировка завершена!</h1>
                                <p className="opacity-90 text-indigo-100">Мозг отлично поработал</p>
                            </div>
                            
                            <div className="p-6 space-y-5">
                                <div className="grid grid-cols-2 gap-4">
                                    <div className="bg-gray-50 p-4 rounded-2xl text-center">
                                        <span className="block text-gray-400 text-xs uppercase font-bold tracking-wider mb-1">Букв пройдено</span>
                                        <span className="block text-4xl font-black text-gray-800">{pairsCount + 1}</span>
                                    </div>
                                    <div className="bg-gray-50 p-4 rounded-2xl text-center">
                                        <span className="block text-gray-400 text-xs uppercase font-bold tracking-wider mb-1">Общее время</span>
                                        <span className="block text-4xl font-black text-gray-800">{formatTime(Math.ceil(timeSpent))}</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div className="p-6 bg-gray-50 space-y-3">
                                <button onClick={handleQuickStart} className="w-full flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-xl shadow transition-all active:scale-95">
                                    <RotateCcw className="w-5 h-5" /> Ещё разок
                                </button>
                                <button onClick={() => setScreen('SETTINGS')} className="w-full flex items-center justify-center gap-2 bg-white border border-gray-200 hover:bg-gray-100 text-gray-700 font-bold py-4 rounded-xl transition-colors">
                                    <Settings className="w-5 h-5" /> В меню
                                </button>
                            </div>
                        </div>
                    </div>
                );
            };

            return (
                <>
                  {screen === 'SETTINGS' && renderStartScreen()}
                  {screen === 'RULES' && renderRules()}
                  {screen === 'GAME' && renderGame()}
                  {screen === 'RESULTS' && renderResults()}
                </>
            );
        }

        const root = createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
